# WM 2026 Tippspiel Discord-Bot – Beispiel-Umgebung
# Kopieren nach `.env` und Werte einsetzen. `.env` ist gitignored – niemals Geheimnisse committen.

# --- Discord (JDA) ---
# Bot-Token aus dem Discord Developer Portal (Bot -> Token)
DISCORD_TOKEN=
# ID des Servers (Guild), auf dem die Slash-Commands registriert werden
DISCORD_GUILD_ID=
# Channel-ID für Reveal-/Auswertungs-Posts
DISCORD_ANNOUNCE_CHANNEL_ID=
# Channel-ID für das selbst-aktualisierende Live-Board (read-only für Mitglieder)
DISCORD_BOARD_CHANNEL_ID=
# Channel-ID für den Info-/Anleitungs-Channel (genau ein gepflegtes Embed; read-only für Mitglieder)
DISCORD_INFO_CHANNEL_ID=

# --- Anzeige-Zeitzone (Persistenz bleibt immer UTC) ---
APP_TIMEZONE_DISPLAY=Europe/Berlin

# --- football-data.org (Spielplan & Ergebnisse, Pflicht) ---
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_API_KEY=

# --- The Odds API (Quoten, optional) ---
# ODDS_ENABLED=false  -> Quoten-Sync deaktiviert; übrige Funktionen laufen ohne Quoten
ODDS_ENABLED=false
ODDS_BASE_URL=https://api.the-odds-api.com/v4
ODDS_API_KEY=

# --- PostgreSQL ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/wmtippspiel
SPRING_DATASOURCE_USERNAME=wmtippspiel
SPRING_DATASOURCE_PASSWORD=

# --- Job-Intervalle (optional, Millisekunden; Defaults in application.yml) ---
# APP_JOBS_SYNC_INTERVAL_MS=900000          # Spielplan-Sync (~15 Min)
# APP_JOBS_REVEAL_INTERVAL_MS=60000         # Reveal-Prüfung (minütlich)
# APP_JOBS_EVALUATE_INTERVAL_MS=60000       # Auswertungs-Prüfung (minütlich)
# APP_JOBS_BOARD_REFRESH_INTERVAL_MS=900000 # Live-Board-Refresh (~15 Min)
# APP_JOBS_ODDS_INTERVAL_MS=21600000        # Quoten-Sync (~6 Std)
