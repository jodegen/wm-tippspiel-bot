# WM 2026 Tippspiel Discord-Bot – Beispiel-Umgebung
# Kopieren nach `.env` und Werte einsetzen. `.env` ist gitignored – niemals Geheimnisse committen.

# --- Discord (JDA) ---
# Bot-Token aus dem Discord Developer Portal (Bot -> Token)
DISCORD_TOKEN=
# ID des Servers (Guild), auf dem die Slash-Commands registriert werden
DISCORD_GUILD_ID=
# Channel-ID für Reveal-/Auswertungs-Posts
DISCORD_ANNOUNCE_CHANNEL_ID=
# Channel-ID für das selbst-aktualisierende Live-Board (read-only für Mitglieder)
DISCORD_BOARD_CHANNEL_ID=
# Channel-ID für den Info-/Anleitungs-Channel (genau ein gepflegtes Embed; read-only für Mitglieder)
DISCORD_INFO_CHANNEL_ID=
# Channel-ID für den Tipp-Channel (kurzes Embed + "Jetzt tippen"-Button; read-only für Mitglieder)
DISCORD_TIP_CHANNEL_ID=
# Rollen-ID für "WM-Notify": Rollenmitglieder werden bei Announce-Posts/Anpfiff-Hinweisen
# gepingt und (falls noch nicht getippt) an offene Tipps erinnert. Der Button im Info-Channel
# vergibt/entzieht diese Rolle.
# Voraussetzungen:
#  - Bot-Recht "Manage Roles"; seine höchste Rolle MUSS ÜBER dieser Rolle stehen.
#  - Privileged "Server Members Intent" im Discord Developer Portal AKTIVIEREN
#    (nötig, um gezielt nur Rollenmitglieder ohne Tipp zu erinnern).
DISCORD_NOTIFY_ROLE_ID=

# --- Tipp-Erinnerung (optional) ---
# Wie viele Minuten vor Anpfiff Abonnenten erinnert werden, die noch nicht getippt haben.
REMINDER_LEAD_MINUTES=60
# Wie viele Minuten vor Anpfiff der allgemeine "Anpfiff steht bevor"-Post (mit Role-Ping) kommt.
KICKOFF_NOTICE_LEAD_MINUTES=10

# --- Live-Tor-Benachrichtigungen (F8, optional) ---
# Poll-Intervall im Live-Fenster (kickoff … +2,5h) in Millisekunden. Default 60000 (60s).
APP_JOBS_LIVE_GOAL_POLL_INTERVAL_MS=60000

# --- Anzeige-Zeitzone (Persistenz bleibt immer UTC) ---
APP_TIMEZONE_DISPLAY=Europe/Berlin

# --- football-data.org (Spielplan & Ergebnisse, Pflicht) ---
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_API_KEY=

# --- The Odds API (Quoten, optional) ---
# ODDS_ENABLED=false  -> Quoten-Sync deaktiviert; übrige Funktionen laufen ohne Quoten
ODDS_ENABLED=false
ODDS_BASE_URL=https://api.the-odds-api.com/v4
ODDS_API_KEY=

# --- Öffentliche Read-only-API (Feature 008) ---
# HTTP-Port des Servlet-Servers für /api/public/** (Default 8080).
SERVER_PORT=8080
# Erlaubte CORS-Origins der Frontend-Website, kommagetrennt. Frontend und API
# laufen auf demselben vServer, aber unter getrennten (Sub-)Domains -> CORS nötig.
# Hier die EXAKTE Frontend-Origin eintragen (Schema + Host, ohne Pfad).
PUBLIC_API_CORS_ALLOWED_ORIGINS=https://app.meine-domain.de
# PFLICHT: Secret für den stabilen, nicht-sensiblen öffentlichen Spieler-Identifier
# (HMAC der internen ID). Langer Zufallswert; ohne Wert schlägt der Start fehl.
PUBLIC_API_ID_SECRET=
# Kurze Cache-TTL (Sekunden) für Spielplan/Leaderboard zum DB-Schutz.
PUBLIC_API_CACHE_TTL_SECONDS=5
# Optional: explizite öffentliche Basis-URL für die OpenAPI-/Swagger-server-URL,
# z. B. https://api.meine-domain.de. Nur nötig, wenn die Swagger-UI hinter dem
# TLS-Proxy "Failed to fetch" zeigt (Mixed Content) und X-Forwarded-* nicht greift.
PUBLIC_API_PUBLIC_BASE_URL=

# --- Öffentliche Website (Feature 009) ---
# Basis-URL der Website für die dezenten Hinweise/Links in den Discord-Ausgaben
# (Board-Footer, /profil, /rangliste). Leer ⇒ keine Hinweise. Getrennt vom API-Host
# (PUBLIC_API_PUBLIC_BASE_URL).
WEBSITE_BASE_URL=https://wm.xenoria.de

# --- PostgreSQL ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/wmtippspiel
SPRING_DATASOURCE_USERNAME=wmtippspiel
SPRING_DATASOURCE_PASSWORD=

# --- Job-Intervalle (optional, Millisekunden; Defaults in application.yml) ---
# APP_JOBS_SYNC_INTERVAL_MS=900000          # Spielplan-Sync (~15 Min)
# APP_JOBS_REVEAL_INTERVAL_MS=60000         # Reveal-Prüfung (minütlich)
# APP_JOBS_EVALUATE_INTERVAL_MS=60000       # Auswertungs-Prüfung (minütlich)
# APP_JOBS_BOARD_REFRESH_INTERVAL_MS=900000 # Live-Board-Refresh (~15 Min)
# APP_JOBS_ODDS_INTERVAL_MS=21600000        # Quoten-Sync (~6 Std)
